{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "YanClaw",
	"version": "0.8.0",
	"identifier": "com.yanclaw.app",
	"build": {
		"frontendDist": "../packages/web/dist",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "bun run --filter @yanclaw/web dev",
		"beforeBuildCommand": "bun run --filter @yanclaw/web build && bun run --filter @yanclaw/server build:compile"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "YanClaw",
				"width": 1200,
				"height": 800,
				"minWidth": 800,
				"minHeight": 600,
				"resizable": true,
				"fullscreen": false,
				"center": true,
				"visible": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["msi", "nsis", "dmg", "deb", "rpm"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"resources": ["server/*"],
		"windows": {
			"wix": {
				"language": "en-US"
			},
			"nsis": {
				"languages": ["English", "SimpChinese"],
				"displayLanguageSelector": true
			}
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzODRBNTU3Q0QzNzI2RTkKUldUcEpqZk5WNldFbzF4REFRQWFRZzQwQWx0RWFvMkt4KzU5cG92SlFaaDl4TU91cEFJUS9JdTIK",
			"endpoints": ["https://github.com/yzlabai/yanclaw/releases/latest/download/latest.json"],
			"windows": {
				"installMode": "passive"
			}
		},
		"global-shortcut": null
	}
}
